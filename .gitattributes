# Normalize line endings
* text=auto

# Source files
*.rs text
*.py text
*.ts text
*.tsx text
*.js text
*.jsx text
*.go text
*.rs.text text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.mov binary
*.pdf binary
*.ico binary
*.icns binary

# Lockfiles
*.lock text
Cargo.lock text
package-lock.json text
pnpm-lock.yaml text
bun.lockb binary
yarn.lock text

# Docs
*.md text
*.mdx text
*.yml text
*.yaml text
*.toml text
*.json text

# Shell
*.sh text eol=lf
